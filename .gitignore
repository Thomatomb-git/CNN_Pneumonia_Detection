# ==========================================
# Git Ignore for Pneumonia Detection Project
# ==========================================

# --- Keras & Machine Learning Models ---
# Keras model files can be very large (up to 260MB+) and should not be tracked by Git.
*.keras
*.h5
*.hdf5
*.pkl
*.npy
*.npz

# --- Large Datasets ---
# Ignore semua isi file gambar di dalam folder dataset, tapi pertahankan struktur foldernya.
model/dataset/**/*
!model/dataset/**/.gitkeep
!model/dataset/**/

# --- Python Environment & Cache ---
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/
venv/
.venv/
env/
.env

# --- IDEs and Editors ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- OS-generated files ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
